<Window
    x:Class="AureusControl.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AureusControl">

    <Grid x:Name="RootGrid"
          Background="{ThemeResource AppBackgroundBrush}">

        <!-- ===== DEFINICIÓN DE FILAS ===== -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- ===== MENU BAR SUPERIOR ===== -->
        <MenuBar Grid.Row="0">

            <MenuBarItem Title="Archivo">
                <MenuFlyoutItem Text="Salir"/>
            </MenuBarItem>

            <MenuBarItem Title="Ver">
                <MenuFlyoutItem Text="Actualizar"/>
                <MenuFlyoutSubItem Text="Appearance">
                    <RadioMenuFlyoutItem x:Name="LightAppearanceItem"
                                         Text="Light"
                                         GroupName="AppearanceMode"
                                         IsChecked="True"
                                         Click="LightAppearance_Click"/>
                    <RadioMenuFlyoutItem x:Name="DarkAppearanceItem"
                                         Text="Dark"
                                         GroupName="AppearanceMode"
                                         Click="DarkAppearance_Click"/>
                </MenuFlyoutSubItem>
            </MenuBarItem>

            <MenuBarItem Title="Herramientas">
                <MenuFlyoutItem Text="Opciones"/>
            </MenuBarItem>

            <MenuBarItem Title="Ayuda">
                <MenuFlyoutItem Text="Acerca de"/>
            </MenuBarItem>

        </MenuBar>

        <!-- ===== TOOLBAR SUPERIOR ===== -->
        <Border Grid.Row="1"
                Background="{ThemeResource AppSurfaceBrush}"
                Padding="10">

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">

                <TextBlock Text="Bot ID:"
                           Foreground="{ThemeResource AppPrimaryTextBrush}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="BotIdTextBox"
                         Width="220"
                         PlaceholderText="Introduce bot_id"/>

                <Button Content="Cargar"
                        Click="LoadBot_Click"/>

                <TextBlock Text="Modo"
                           Foreground="{ThemeResource AppPrimaryTextBrush}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <ComboBox x:Name="LoadModeComboBox"
                          Width="140"
                          SelectionChanged="LoadModeComboBox_SelectionChanged">
                    <x:String>All</x:String>
                    <x:String>BUY/SELL</x:String>
                    <x:String>Symbol</x:String>
                </ComboBox>

                <ComboBox x:Name="SymbolComboBox"
                          Width="200"
                          PlaceholderText="Selecciona símbolo"
                          SelectionChanged="SymbolComboBox_SelectionChanged"/>

            </StackPanel>
        </Border>

        <!-- ===== CONTENIDO PRINCIPAL ===== -->
        <NavigationView Grid.Row="2"
                        x:Name="NavView"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavView_SelectionChanged"
                        IsSettingsVisible="False">

            <NavigationView.MenuItems>

                <NavigationViewItem x:Name="DataTab" Content="Visualizar Data" Tag="csv">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="LogsTab" Content="Logs" Tag="log">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="EntriesTab" Content="Entries" Tag="entries">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="List"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="ConfigTab" Content="Config" Tag="config">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="ChartsTab" Content="Charts" Tag="charts">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="View"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Stats">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="View"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="20" Spacing="8">
                    <TextBlock x:Name="MachineText"
                               FontSize="16"
                               Foreground="{ThemeResource AppPrimaryTextBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="ViewerStatusText"
                               Foreground="{ThemeResource AppSecondaryTextBrush}"
                               Opacity="0.95"/>
                </StackPanel>

                <Frame x:Name="ContentFrame" Grid.Row="1"/>
            </Grid>

        </NavigationView>

    </Grid>

</Window>
