<Window
    x:Class="AureusControl.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AureusControl">

    <Grid>

        <!-- ===== DEFINICIÓN DE FILAS ===== -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- ===== MENU BAR SUPERIOR ===== -->
        <MenuBar Grid.Row="0">

            <MenuBarItem Title="Archivo">
                <MenuFlyoutItem Text="Salir"/>
            </MenuBarItem>

            <MenuBarItem Title="Ver">
                <MenuFlyoutItem Text="Actualizar"/>
            </MenuBarItem>

            <MenuBarItem Title="Herramientas">
                <MenuFlyoutItem Text="Opciones"/>
            </MenuBarItem>

            <MenuBarItem Title="Ayuda">
                <MenuFlyoutItem Text="Acerca de"/>
            </MenuBarItem>

            <MenuBarItem Title="Settings">
                <MenuFlyoutItem Text="DB Config" Click="DbConfig_Click"/>
            </MenuBarItem>

        </MenuBar>

        <!-- ===== TOOLBAR SUPERIOR ===== -->
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="10">

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">

                <TextBlock Text="Bot ID:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="BotIdTextBox"
                         Width="220"
                         PlaceholderText="Introduce bot_id"/>

                <Button Content="Cargar"
                        Click="LoadBot_Click"/>

                <TextBlock Text="Modo"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <ComboBox x:Name="LoadModeComboBox"
                          Width="140"
                          SelectionChanged="LoadModeComboBox_SelectionChanged">
                    <x:String>All</x:String>
                    <x:String>BUY/SELL</x:String>
                    <x:String>Symbol</x:String>
                </ComboBox>

                <ComboBox x:Name="SymbolComboBox"
                          Width="200"
                          PlaceholderText="Selecciona símbolo"
                          SelectionChanged="SymbolComboBox_SelectionChanged"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="DB" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Ellipse x:Name="DbStatusLamp" Width="14" Height="14" Fill="Red"/>
                    <TextBlock x:Name="DbStatusText" Text="Sin conexión" VerticalAlignment="Center"/>
                </StackPanel>

                <CheckBox x:Name="LiveModeCheckBox"
                          Content="Live"
                          VerticalAlignment="Center"
                          IsChecked="False"
                          Checked="LiveModeCheckBox_Changed"
                          Unchecked="LiveModeCheckBox_Changed"/>

            </StackPanel>
        </Border>

        <!-- ===== CONTENIDO PRINCIPAL ===== -->
        <NavigationView Grid.Row="2"
                        x:Name="NavView"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavView_SelectionChanged"
                        IsSettingsVisible="False">

            <NavigationView.MenuItems>

                <NavigationViewItem x:Name="DataTab" Content="Visualizar Data" Tag="csv">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="LogsTab" Content="Logs" Tag="log">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="EntriesTab" Content="Entries" Tag="entries">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="List"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="ConfigTab" Content="Config" Tag="config">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="ChartsTab" Content="Charts" Tag="charts">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="View"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Stats">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="View"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="SummaryTab" Content="Summary" Tag="summary">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="List"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="20" Spacing="8">
                    <TextBlock x:Name="MachineText"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="ViewerStatusText" Opacity="0.8"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Frame x:Name="ContentFrame"/>

                    <ScrollViewer x:Name="SummaryPanel" Visibility="Collapsed" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Summary de bots running" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SummaryModeText" Opacity="0.85"/>

                            <ListView x:Name="SummaryListView" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                CornerRadius="10"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding Fields}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnSpacing="10" Margin="0,2,0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="220"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Key}" FontWeight="SemiBold" Opacity="0.85"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

        </NavigationView>

    </Grid>

</Window>
