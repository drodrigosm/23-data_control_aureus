<Page
    x:Class="AureusControl.Views.LargeFileViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="12"
                    Padding="12"
                    VerticalAlignment="Center">

            <TextBlock x:Name="TitleText"
                       FontSize="16"
                       Foreground="{ThemeResource AppPrimaryTextBrush}"
                       FontWeight="SemiBold"/>

            <ProgressRing x:Name="LoadingRing"
                          Width="18"
                          Height="18"
                          IsActive="False"/>

            <TextBlock x:Name="StatusText"
                       Foreground="{ThemeResource AppSecondaryTextBrush}"
                       Opacity="0.8"/>
        </StackPanel>

        <Grid Grid.Row="1" Padding="12,0,12,8" ColumnSpacing="12" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTextBox"
                     Grid.Row="0"
                     Grid.Column="0"
                     MinWidth="280"
                     Foreground="{ThemeResource AppPrimaryTextBrush}"
                     Background="{ThemeResource AppSurfaceBrush}"
                     PlaceholderText="Buscar en todo el fichero..."
                     TextChanged="SearchTextBox_TextChanged"/>

            <Button x:Name="ClearFiltersButton"
                    Grid.Row="0"
                    Grid.Column="1"
                    Content="Limpiar filtros"
                    Foreground="{ThemeResource AppPrimaryTextBrush}"
                    Background="{ThemeResource AppSurfaceBrush}"
                    Click="ClearFiltersButton_Click"/>

            <Expander Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Header="Mostrar/Ocultar columnas"
                      IsExpanded="False">
                <ScrollViewer MaxHeight="130"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ColumnTogglePanel" Orientation="Horizontal" Spacing="8"/>
                </ScrollViewer>
            </Expander>
        </Grid>

        <ListView x:Name="CsvGrid"
                  Grid.Row="2"
                  Margin="12,0,12,0"
                  Foreground="{ThemeResource AppPrimaryTextBrush}"
                  Background="{ThemeResource AppSurfaceBrush}"
                  IsItemClickEnabled="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="3"
                   x:Name="FooterText"
                   Padding="12"
                   Foreground="{ThemeResource AppSecondaryTextBrush}"
                   Opacity="0.8"
                   HorizontalAlignment="Right"/>
    </Grid>
</Page>
